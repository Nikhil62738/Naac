PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/naac_file_management
JWT_SECRET=change-this-secret
CLIENT_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads

# Email (Gmail SMTP for local, Gmail API OAuth2 for Render)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password (local only)

# Gmail API OAuth2 (Required for Render)
GMAIL_CLIENT_ID=your-client-id
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
